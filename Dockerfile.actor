FROM apify/actor-python:3.11

WORKDIR /usr/src/app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

COPY pyproject.toml ./
COPY server.py actor_main.py ./
COPY knowledge/ ./knowledge/
COPY schemas/ ./schemas/

RUN pip install --upgrade pip && pip install -e ".[apify]"

CMD ["python", "actor_main.py"]
